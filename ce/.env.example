# FYY Community Edition — Environment Variables
# Copy to .env and adjust before starting.
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=feiyueyun
POSTGRES_PASSWORD=generate-a-strong-password-here
POSTGRES_DB=feiyueyun

# --- Redis ---
# No password by default (internal Docker network)

# --- NATS ---
# No auth by default (internal Docker network)

# --- Platform Admin ---
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD=generate-a-strong-password-here

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_MASTER_KEY=generate-a-256-bit-hex-key-here

# --- DERP ---
DERP_HOSTNAME=derp.example.com
# Set DERP_CERT_SHA256 after first run (see logs for value), or leave empty for auto-generation
DERP_CERT_SHA256=

# --- Auto-Provisioning ---
# Enable zero-interaction device onboarding (default: true)
AUTHKEY_AUTO_ENABLED=true

# --- MinIO (Object Storage) ---
MINIO_ACCESS_KEY=feiyueyun
MINIO_SECRET_KEY=generate-a-strong-password-here

# --- Control Plane Hostname ---
# Public hostname for your control plane (used by mesh-ctrl)
FYY_CONTROL_PLANE_HOST=localhost
# Channel 2 URL for CLI devices
CHANNEL2_URL=http://localhost:8080

# --- OAuth2 (Optional, for Owner Binding) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:8080/v1/auth/callback/github
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/v1/auth/callback/google

# --- Log Level ---
LOG_LEVEL=INFO
